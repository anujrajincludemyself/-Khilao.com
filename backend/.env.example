# Database
CONNECTION_STRING=your_mongodb_connection_string

# JWT
SECRET_KEY=your_secret_key_here

# Cloudinary Configuration
# Sign up at https://cloudinary.com (FREE)
# Get these from: Dashboard > Account Details
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Groq API Configuration
# Generate key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FALLBACKS=llama-3.1-8b-instant,mixtral-8x7b-32768
GROQ_BASE_URL=https://api.groq.com/openai/v1

# AI endpoint hardening/performance
AI_RATE_LIMIT_MAX=8
AI_RATE_LIMIT_WINDOW_MS=3600000
AI_CACHE_TTL_MS=900000

# Server
PORT=5000
NODE_ENV=production
